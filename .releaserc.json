{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/exec", {
      "prepareCmd": "scripts/bump-version.sh ${nextRelease.version} && scripts/build-release.sh ${nextRelease.version}"
    }],
    ["@semantic-release/git", {
      "assets": ["project.yml", "appcast.xml"],
      "message": "chore(release): v${nextRelease.version} [skip ci]"
    }],
    ["@semantic-release/github", {
      "assets": [
        { "path": "build/release/Messenger-*.dmg", "label": "Messenger-${nextRelease.version}.dmg" }
      ]
    }]
  ]
}
